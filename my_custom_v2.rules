
#File Upload Detection
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"Potential PHP File Upload";flow:to_server,established;content:".php";http_client_body;content:"/DVWA/vulnerabilities/upload/";nocase;http_uri;nocase;sid:10000132;rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"Potential JS File Upload";flow:to_server,established;content:".js";http_client_body;content:"/DVWA/vulnerabilities/upload/";nocase;http_uri;nocase;sid:10000131;rev:1;)


#PortScanning
alert tcp $EXTERNAL_NET any -> $HOME_NET ![80,53,5353] (msg:"Potential TCP Port Scan Detected";flow:to_server;detection_filter:track by_src,count 4,seconds 30;sid:10000002;rev:1;)
alert udp $EXTERNAL_NET any -> $HOME_NET ![53,5353] (msg:"Potential UDP Port Scan Detected";flow:to_server;detection_filter:track by_src,count 4,seconds 30;sid:10000004;rev:1;)

