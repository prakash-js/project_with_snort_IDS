#DOS attack (HIGH TRAFFIC RATE)
alert tcp any any -> $HOME_NET any (detection_filter: track by_src, count 1000, seconds 1; msg: "TCP-flag-type flood Attack  Detected";classtype:denial-of-service; sid:10000101;rev:1;)
alert icmp any any -> $HOME_NET any (detection_filter: track by_src, count 1000, seconds 1; msg: "ICMP flood Attack  Detected";classtype:denial-of-service sid:10000102;rev:1;)
alert tcp any any -> $HOME_NET any (detection_filter: track by_src, count 2000, seconds 1; msg: "Very Intense TCP-flag-type flood attack is Detected ";classtype:denial-of-service sid:10000103;rev:1;)
alert udp any any -> $HOME_NET any (detection_filter: track by_src, count 1000, seconds 1; msg: "UDP flood Attack Detected";classtype:denial-of-service sid:10000104;rev:1;)
alert udp any any -> $HOME_NET any (detection_filter: track by_src, count 2000, seconds 1; msg: "Very Intense udp flood Attack Detected";classtype:denial-of-service sid:10000105;rev:1;)


# Automation Tool Detection via HTTP-HEADER(useragent)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"Nikto Scanner Detected";flow:to_server,established;content:"Nikto"; http_header; nocase;classtype:attempted-recon;sid:10000124; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"Sqlmap Scanner Detected";flow:to_server,established;content:"sqlmap"; http_header; nocase;classtype:attempted-recon;sid:10000125; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"FFUF Scanner Detected";flow:to_server,established;content:"FUZZ"; http_header; nocase;classtype:attempted-recon;sid:10000126; rev:2;)


#Reverse Connection Detection
alert tcp $HOME_NET !80 -> $EXTERNAL_NET !80 (msg:"Potential Reverse Connection via TCP Detected"; flags:PA; sid:1100001;rev:1;)
alert tcp $EXTERNAL_NET  !80 ->  $HOME_NET !80 (msg:"Potential Reverse Connection via TCP Detected";content:"/bin/bash";nocase;classtype:malware-cnc;sid:1100002;rev:1;)
alert tcp $HOME_NET  !80 -> $EXTERNAL_NET !80 (msg:"Potential Reverse Connection via TCP Detected";content:"/bin/bash";nocase;classtype:malware-cnc;sid:1100003;rev:1;)
alert tcp $EXTERNAL_NET  !80 ->  $HOME_NET !80 (msg:"Potential Reverse Connection via TCP Detected";content:"service --status-all";nocase;classtype:malware-cnc;sid:1100004;rev:1;)
alert tcp $HOME_NET !80 ->  $EXTERNAL_NET !80 (msg:"Potential Reverse Connection via TCP Detected";content:"service --status-all";nocase;classtype:malware-cnc;sid:1100005;rev:1;)
alert tcp $EXTERNAL_NET  !80 ->  $HOME_NET !80 (msg:"Potential Reverse Connection via TCP Detected";content:"sudo -l";nocase;classtype:malware-cnc;sid:1100006;rev:1;)
alert tcp $HOME_NET !80 ->  $EXTERNAL_NET !80 (msg:"Potential Reverse Connection via TCP Detected";content:"sudo -l";nocase;classtype:malware-cnc;sid:1100007;rev:1;)
alert udp $HOME_NET 0:65535 ->  $EXTERNAL_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"www-data";nocase;classtype:malware-cnc;sid:1100008;rev:1;)
alert udp $EXTERNAL_NET 0:65535 ->  $HOME_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"www-data";nocase;classtype:malware-cnc;sid:1100009;rev:1;)
alert udp $HOME_NET 0:65535 ->  $EXTERNAL_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"/bin/bash";nocase;classtype:malware-cnc; sid:11000010;rev:1;)
alert udp $EXTERNAL_NET 0:65535 ->  $HOME_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"/bin/bash";nocase;classtype:malware-cnc; sid:11000011;rev:1;)
alert udp $EXTERNAL_NET 0:65535 ->  $HOME_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"sudo -l";nocase;classtype:malware-cnc; sid:11000012;rev:1;)
alert udp $HOME_NET 0:65535 ->  $EXTERNAL_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"sudo -l";nocase;classtype:malware-cnc; sid:11000013;rev:1;)
alert udp $HOME_NET 0:65535 ->  $EXTERNAL_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"pwd";nocase;classtype:malware-cnc; sid:11000014;rev:1;)
alert udp $EXTERNAL_NET 0:65535 ->  $HOME_NET any (msg:"Potential Reverse Connection via UDP Detected";content:"pwd";nocase;classtype:malware-cnc; sid:11000015;rev:1;)


#This rule(sid:1100001) was developed for a controlled lab environment using a dual-interface network configuration.
#The web server handled external web traffic through adedicated interface, while operating system traffic was routed through a separate higher-metric interface.
#Internal trusted devices were whitelisted. 
#Under these conditions, unexpected outbound non-web connections were treated as potential reverse shell activity.
